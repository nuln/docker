TZ=Asia/Shanghai

# === 认证（必填！设置后 Web UI / API 需要密码）===
PASEO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Paseo daemon 配置 ===
# 监听地址（默认 0.0.0.0:6767）
PASEO_LISTEN=0.0.0.0:6767
# 日志级别: debug / info / warn / error
PASEO_LOG_LEVEL=info
# 启用 Web UI
PASEO_WEB_UI_ENABLED=true

# === 资源限制 ===
MEM_LIMIT=2g
CPU_LIMIT=2
