# iCloud 加密镜像（CI 推送后填 ghcr.io/nuln/icloud:latest；本地可改 icloud-local 自构建）
ICLOUD_IMAGE=ghcr.io/nuln/icloud:latest

# 运行用户（保持与镜像内 abc 用户 uid/gid 一致，避免权限错乱）
PUID=1000
PGID=1000

# 时区
TZ=Asia/Shanghai

# ⚠️ 加密口令：每次启动都必须提供【同一个】KEYRING_PASSPHRASE
# 忘记就只能删 ./config/python_keyring/ 重新手动登录。
# 用 openssl rand -base64 24 生成一个强口令填这里。
KEYRING_PASSPHRASE=

# 弱机资源限制
MEM_LIMIT=1g
CPU_LIMIT=2
