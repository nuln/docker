TZ=Europe/Berlin
# === 认证（必填！留空 = 无密码 = 任何人可访问你的 OpenCode）===
# 用户名默认 opencode；密码请设强密码，并在手机/API 客户端用 Basic Auth 携带
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- 弱机资源限制（默认值按 Intel J3455 保守配置） ---
# cargo 并行编译任务数：J3455 用 1，N5105 可设 2
CARGO_BUILD_JOBS=1
# Go 编译/运行并行度
GOMAXPROCS=2
# make 并行（C / Python 源码编译等）
MAKEFLAGS=-j2
# 容器内存上限（如 4g / 6g）
MEM_LIMIT=4g
# 容器可用 CPU 核数（J3455 可设 1，N5105 设 2）
CPU_LIMIT=2
