{
  "$schema": "https://opencode.ai/config.json",

  "server": {},

  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "opencode/big-pickle",

  "provider": {
    "opencode": {
      "name": "OpenCode (official free models)",
      "models": {
        "big-pickle": { "name": "Big Pickle (free)" },
        "hy3-free": { "name": "HY3 Free" },
        "deepseek-v4-flash-free": { "name": "DeepSeek V4 Flash (Free)" },
        "mimo-v2.5-free": { "name": "Mimo 2.5 (Free)" },
        "nemotron-3-ultra-free": { "name": "Nemotron 3 Ultra (Free)" },
        "north-mini-code-free": { "name": "North Mini Code (Free)" }
      }
    },

    "opencode-go": {
      "name": "OpenCode Go (subscription)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash (Go)" },
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro (Go)" },
        "glm-5.1": { "name": "GLM 5.1 (Go)" },
        "glm-5.2": { "name": "GLM 5.2 (Go)" },
        "grok-4.5": { "name": "Grok 4.5 (Go)" },
        "kimi-k2.6": { "name": "Kimi K2.6 (Go)" },
        "kimi-k2.7-code": { "name": "Kimi K2.7 Code (Go)" },
        "kimi-k3": { "name": "Kimi K3 (Go)" },
        "mimo-v2.5": { "name": "MiMo 2.5 (Go)" },
        "mimo-v2.5-pro": { "name": "MiMo 2.5 Pro (Go)" },
        "minimax-m2.7": { "name": "MiniMax M2.7 (Go)" },
        "minimax-m3": { "name": "MiniMax M3 (Go)" },
        "qwen3.6-plus": { "name": "Qwen3.6 Plus (Go)" },
        "qwen3.7-max": { "name": "Qwen3.7 Max (Go)" }
      }
    }
  },

  "agent": {
    "coder": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "task": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "title": {
      "model": "opencode/big-pickle"
    },
    "explain": {
      "model": "opencode/hy3-free"
    },
    "chat": {
      "model": "opencode/big-pickle"
    },
    "mini": {
      "model": "opencode/north-mini-code-free"
    },
    "free": {
      "model": "opencode/big-pickle"
    },
    "list": {
      "model": "opencode/mimo-v2.5-free"
    }
  }
}
