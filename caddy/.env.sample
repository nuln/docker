# Caddy 镜像（CI 推送后填 ghcr.io/nuln/caddy:latest；本地可改成 caddy-local 自构建）
CADDY_IMAGE=ghcr.io/nuln/caddy:latest

# 时区
TZ=Asia/Shanghai

# 弱机资源限制（参考 opencode 子项目约定）
MEM_LIMIT=512m
CPU_LIMIT=1

# Cloudflare DNS-01 验证 API Token（申请证书用，仅 Zone:DNS 编辑权限）
# 不填则回退到 HTTP-01 验证（需 80 端口可被公网访问）
CF_DNS_API_TOKEN=

# caddy-security 对接 PocketID 的 OIDC 凭据
# 在 PocketID 后台创建 OIDC Client，callback 填：
#   https://<本caddy域名>/caddy-security/oauth2/pocketid/authorization-code-callback
POCKETID_CLIENT_ID=
POCKETID_CLIENT_SECRET=

# caddy-security 签发/校验 JWT 的共享密钥（openssl rand -base64 32 生成）
JWT_SECRET=
