TZ=Asia/Shanghai

# === Manager 配置 ===
# Manager Admin 密码（必填）
MANAGER_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
# 允许使用 ?password= 查询参数进行管理员 API 调用（Docker 启动时自动注册 Proxy 需要）
MANAGER_ALLOW_LEGACY_ADMIN_PASSWORD=1
# 预配置的 Proxy URL 列表（逗号分隔），格式: https://host/path
# Proxy 的密码由 PROXY_PASSWORD 统一设置
PROXIES=https://relay.example.com

# === Proxy 配置 ===
# Manager API 地址（内部网络可用 http，公网必须 HTTPS）
MANAGER_URL=http://manager:8899
# Proxy 公网地址（与 Caddy 域名/路径一致，必须 HTTPS）
PUBLIC_URL=https://relay.example.com
# 二级目录时:
# PUBLIC_URL=https://relay.example.com/lunel
# Proxy 认证密码（必填）
PROXY_PASSWORD=CHANGE_ME_PROXY_PASSWORD
# 是否强制 Manager 校验（设为 0 可跳过，仅开发用）
ENFORCE_MANAGER_AUTHORITY=1

# === 资源限制 ===
MEM_LIMIT=1g
CPU_LIMIT=1
