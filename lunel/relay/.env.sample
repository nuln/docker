# === Proxy 中继配置 ===
# Proxy 监听端口
PORT=3000
# 对外暴露端口
RELAY_PORT=3000

# Manager API 地址（必须 HTTPS）
MANAGER_URL=https://manager.example.com
# Proxy 公网地址（必须 HTTPS，与 Caddy 域名/路径一致）
PUBLIC_URL=https://relay.example.com
# 二级目录时包含路径：
# PUBLIC_URL=https://relay.example.com/lunel

# Proxy 认证密码（与 Manager PROXIES 或注册时一致）
PROXY_PASSWORD=CHANGE_ME_PROXY_PASSWORD

# 日志级别（对于 Proxy 没有独立 LOG_LEVEL 环境变量，留空即可）
LOG_LEVEL=info
